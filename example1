import java.util.Scanner;

class NewtonSimple {

    // f(x) = x³ - 2x - 5
    public static double f(double x) {
        return x * x * x - 2 * x - 5;
    }

    // f'(x) = 3x² - 2
    public static double df(double x) {
        return 3 * x * x - 2;
    }

    public static void solveNewtonMethod(double initialX, double eps) {
        double x = initialX;
        int iterations = 0;

        System.out.println("Решение уравнения x³ - 2x - 5 = 0");
        System.out.println("Начальное приближение: x₀ = " + x);
        System.out.println("Точность: " + eps);
        System.out.println();

        while (true) {
            iterations++;
            double fx = f(x);
            double dfx = df(x);

            if (Math.abs(dfx) < 1e-15) {
                System.out.println("Производная равна нулю!");
                break;
            }

            double x_new = x - fx / dfx;
            double delta = Math.abs(x_new - x);

            System.out.printf("Итерация %d: x = %.8f, f(x) = %.10f, Δx = %.8f%n",
                    iterations, x, fx, delta);

            if (delta < eps) {
                x = x_new;
                break;
            }

            x = x_new;
        }
        System.out.printf("Корень уравнения: x = %.8f%n", x);
        System.out.printf("Количество итераций: %d%n", iterations);
        System.out.printf("Значение функции: f(x) = %.10f%n", f(x));
    }
    public static double findRootNewton(double initialX, double eps) {
        double x = initialX;
        int iterations = 0;

        while (true) {
            iterations++;
            double fx = f(x);
            double dfx = df(x);

            if (Math.abs(dfx) < 1e-15) {
                System.out.println("Предупреждение: Производная равна нулю!");
                return Double.NaN;             }

            double x_new = x - fx / dfx;
            double delta = Math.abs(x_new - x);

            if (delta < eps) {
                System.out.println("Количество итераций: " + iterations);
                return x_new;
            }

            x = x_new;
        }
    }
    public static NewtonResult findRootWithDetails(double initialX, double eps) {
        double x = initialX;
        int iterations = 0;

        while (true) {
            iterations++;
            double fx = f(x);
            double dfx = df(x);

            if (Math.abs(dfx) < 1e-15) {
                return new NewtonResult(Double.NaN, iterations, false);
            }

            double x_new = x - fx / dfx;
            double delta = Math.abs(x_new - x);

            if (delta < eps) {
                return new NewtonResult(x_new, iterations, true);
            }

            x = x_new;
        }
    }

    public static void main(String[] args) {
        double x = 2.0;
        double eps = 0.0001;
        solveNewtonMethod(x, eps);
    }
}

class NewtonResult {
    double root;
    int iterations;
    boolean success;

    NewtonResult(double root, int iterations, boolean success) {
        this.root = root;
        this.iterations = iterations;
        this.success = success;
    }
}
